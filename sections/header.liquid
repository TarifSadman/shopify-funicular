{{ 'header.css' | asset_url | stylesheet_tag }}

<div class="header-section" x-data="{ mobileMenuOpen: false }">
  <div class="header-container">
    <div class="header-inner">
      <!-- STORE NAME / LOGO -->
      <div class="header-logo-area">
        <a href="{{ routes.root_url }}" class="header-logo-link">
          <div class="header-logo-icon">
            <span>◆</span>
          </div>
          <h1 class="header-shop-name">
            {{ shop.name }}
          </h1>
        </a>
      </div>

      <!-- DESKTOP NAV -->
      <nav class="header-nav-desktop">
        {% for link in linklists['main-menu'].links %}
          {% if link.links != blank %}
            <div class="header-nav-item--dropdown" x-data="{ open: false }">
              <button
                @click="open = !open"
                type="button"
                class="header-nav-link"
              >
                {{ link.title }}
                <svg
                  class="transition-transform"
                  :class="{ 'rotate-180': open }"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 -19.04 75.804 75.804"
                  fill="currentColor"
                >
                  <path
                    d="M0.003,1.499A1.5,1.5,0,0,1,2.564.439L36.124,34a2.528,2.528,0,0,0,3.564,0L73.246.439a1.5,1.5,0,1,1,2.121,2.121L41.809,36.117a5.53,5.53,0,0,1-7.807,0L.442,2.56A1.5,1.5,0,0,1,.003,1.499Z"
                  />
                </svg>
              </button>

              <div
                x-show="open"
                x-cloak
                @click.away="open = false"
                x-transition
                class="header-dropdown-content"
              >
                <div class="header-dropdown-inner">
                  <div class="header-dropdown-grid">
                    {% for childlink in link.links %}
                      <a
                        href="{{ childlink.url }}"
                        class="header-dropdown-link"
                      >
                        {{ childlink.title }}
                      </a>
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>

          {% else %}
            <a
              href="{{ link.url }}"
              class="header-nav-link"
            >
              {{ link.title }}
            </a>
          {% endif %}
        {% endfor %}
      </nav>

      <!-- RIGHT ACTIONS -->
      <div class="header-actions">
        <!-- SEARCH INPUT (Desktop Only) -->
        <div class="header-search-desktop" x-data="searchModule()">
          <div class="header-search-form">
            <input
              type="text"
              x-model="searchQuery"
              @input="handleSearch()"
              @keydown.enter="navigateToFirstResult()"
              placeholder="Search..."
              class="header-search-input"
            >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="header-search-icon"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.5 5.5a7.5 7.5 0 0010.5 10.5Z"
              />
            </svg>
          </div>

          <div
            x-show="searchQuery && (searchResults.length > 0 || isLoading)"
            x-cloak
            x-transition
            class="header-search-results"
          >
            <!-- LOADING -->
            <div
              x-show="isLoading"
              class="header-search-loading"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
              >
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              <span>Searching...</span>
            </div>

            <!-- RESULTS -->
            <template x-for="(product, index) in searchResults" :key="product.id">
              <a
                :href="product.url"
                class="header-search-product"
              >
                <img
                  :src="product.image"
                  :alt="product.title"
                  width="48"
                  height="48"
                  class="search-result-image"
                  loading="lazy"
                >
                <div class="search-result-info">
                  <p class="search-result-title" x-text="product.title"></p>
                  <p class="search-result-price" x-text="formatPrice(product.price)"></p>
                </div>
              </a>
            </template>
          </div>
        </div>

        <!-- ACCOUNT -->
        {% if shop.customer_accounts_enabled %}
          <div class="header-nav-item--account" x-data="{ accountOpen: false }">
            <button
              @click="accountOpen = !accountOpen"
              @mouseenter="accountOpen = true"
              class="header-action-btn"
              aria-label="Account"
            >
              {% render 'icon_user' %}
            </button>

            <div
              x-show="accountOpen"
              x-cloak
              @mouseleave="accountOpen = false"
              @click.away="accountOpen = false"
              x-transition
              class="header-account-dropdown"
            >
              <div class="header-dropdown-list">
                {% if customer %}
                  <a
                    href="{{ routes.account_url }}"
                    class="header-dropdown-link"
                  >
                    My Account
                  </a>
                  <a
                    href="{{ routes.account_logout_url }}"
                    class="header-dropdown-link"
                  >
                    Log out
                  </a>
                {% else %}
                  <a
                    href="{{ routes.account_login_url }}"
                    class="header-dropdown-link"
                  >
                    Log in
                  </a>
                  <a
                    href="{{ routes.account_register_url }}"
                    class="header-dropdown-link"
                  >
                    Create account
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}

        <!-- WISHLIST POPUP -->
        <div
          class="header-nav-item--wishlist"
          x-data="{ wishlistOpen: false }"
          @mouseenter="wishlistOpen = true"
          data-trigger="wishlist-drawer"
          @mouseleave="wishlistOpen = false"
        >
          <a
            href="#"
            class="header-action-btn"
            aria-label="Wishlist"
          >
            {% render 'icon_heart', fill: false %}
            <sup
              id="WishlistCount"
              data-currency="{{ cart.currency.iso_code }}"
              class="header-badge header-badge--wishlist hidden"
            >
              0
            </sup>
          </a>

          <!-- Popup Content -->
          <div
            x-show="wishlistOpen"
            x-cloak
            x-transition
            class="header-wishlist-popup"
          >
            <div class="wishlist-popup-header">
              <h3>My Wishlist</h3>
            </div>
            <div id="WishlistContent" class="wishlist-popup-content">
              <!-- Dynamic content from JS -->
              <div class="header-wishlist-empty">
                <p>Your wishlist is empty</p>
              </div>
            </div>
          </div>
        </div>

        <!-- CART -->
        <a
          href="{{ routes.cart_url }}"
          class="header-action-btn"
          aria-label="Cart"
          data-action="open-cart"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="header-icon"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"
            />
          </svg>

          <sup
            id="CartCount"
            class="header-badge header-badge--cart {% if cart.item_count == 0 %}hidden{% endif %}"
          >
            {{ cart.item_count }}
          </sup>
        </a>

        <!-- MOBILE HAMBURGER -->
        <div class="header-mobile-hamburger">
          <button
            x-on:click="mobileMenuOpen = !mobileMenuOpen"
            type="button"
            class="header-hamburger-btn"
          >
            {% render 'icon_hamburger' %}
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- MOBILE MENU -->
  <div
    x-show="mobileMenuOpen"
    x-cloak
    x-transition
    class="header-mobile-menu"
  >
    <div class="header-mobile-menu-inner">
      <div class="header-mobile-content">
        <!-- MOBILE HEADER -->
        <div class="header-mobile-header">
          <h2 class="header-mobile-title">
            {{ section.settings.mobile_menu_title }}
          </h2>

          <button
            x-on:click="mobileMenuOpen = false"
            type="button"
            class="header-mobile-close-btn"
          >
            {% render 'icon_close' %}
          </button>
        </div>

        <!-- MOBILE NAV -->
        <div class="header-mobile-nav">
          <nav class="header-mobile-nav-list">
            {% for link in linklists['main-menu'].links %}
              {% assign link_handle = link.handle | replace: '-', '_' %}

              {% if link.links != blank %}
                <div x-data="{ {{ link_handle }}: false }">
                  <button
                    x-on:click="{{ link_handle }} = !{{ link_handle }}"
                    type="button"
                    class="header-mobile-nav-link"
                  >
                    {{ link.title }}
                    <svg
                      class="transition-transform"
                      :class="{ 'rotate-180': {{ link_handle }} }"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 -19.04 75.804 75.804"
                      fill="currentColor"
                      style="width: 1rem; height: 1rem;"
                    >
                      <path
                        d="M0.003,1.499A1.5,1.5,0,0,1,2.564.439L36.124,34a2.528,2.528,0,0,0,3.564,0L73.246.439a1.5,1.5,0,1,1,2.121,2.121L41.809,36.117a5.53,5.53,0,0,1-7.807,0L.442,2.56A1.5,1.5,0,0,1,.003,1.499Z"
                      />
                    </svg>
                  </button>

                  <div x-show="{{ link_handle }}" x-cloak x-transition class="header-mobile-submenu">
                    {% for childlink in link.links %}
                      <a
                        href="{{ childlink.url }}"
                        class="header-mobile-sublink"
                      >
                        {{ childlink.title }}
                      </a>
                    {% endfor %}
                  </div>
                </div>
              {% else %}
                <a
                  href="{{ link.url }}"
                  class="header-mobile-nav-link"
                >
                  {{ link.title }}
                </a>
              {% endif %}
            {% endfor %}
          </nav>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function searchModule() {
    return {
      searchQuery: '',
      searchResults: [],
      isLoading: false,
      debounceTimer: null,

      formatPrice(price) {
        const amount = parseFloat(price);
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: '{{ cart.currency.iso_code }}' || 'USD',
        }).format(amount);
      },

      navigateToFirstResult() {
        if (this.searchResults.length > 0) {
          window.location.href = this.searchResults[0].url;
        }
      },

      async handleSearch() {
        clearTimeout(this.debounceTimer);

        this.debounceTimer = setTimeout(async () => {
          const query = this.searchQuery.trim();

          if (!query) {
            this.searchResults = [];
            return;
          }

          this.isLoading = true;

          try {
            // Use Shopify's Predictive Search API
            const response = await fetch(
              `/search/suggest.json?q=${encodeURIComponent(query)}&resources[type]=product&resources[limit]=8`
            );

            if (!response.ok) {
              throw new Error('Search failed');
            }

            const data = await response.json();
            const products = data.resources?.results?.products || [];

            this.searchResults = products.map((product) => ({
              id: product.id,
              title: product.title,
              price: product.price,
              compareAtPrice: product.compare_at_price,
              image:
                product.image ||
                product.featured_image ||
                'https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-image_large.png',
              url: product.url,
              available: product.available,
            }));
          } catch (error) {
            // Fallback to products.json for development/testing
            try {
              const fallbackResponse = await fetch('/products.json');
              const productsData = await fallbackResponse.json();
              const lowerQuery = query.toLowerCase();

              this.searchResults = productsData.products
                .filter(
                  (p) =>
                    p.title.toLowerCase().includes(lowerQuery) ||
                    (p.tags && p.tags.some((tag) => tag.toLowerCase().includes(lowerQuery)))
                )
                .slice(0, 8)
                .map((p) => ({
                  id: p.id,
                  title: p.title,
                  price: p.variants[0]?.price || 0,
                  compareAtPrice: p.variants[0]?.compare_at_price,
                  image:
                    (p.images && p.images[0] ? p.images[0].src || p.images[0] : p.featured_image) ||
                    'https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-image_large.png',
                  url: `/products/${p.handle}`,
                  available: p.available,
                }));
            } catch (fallbackError) {
              this.searchResults = [];
            }
          } finally {
            this.isLoading = false;
          }
        }, 300);
      },
    };
  }
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "mobile_menu_title",
      "label": "Title",
      "info": "This is the title of mobile menu",
      "default": "menu"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Header",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
