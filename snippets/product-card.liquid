<div class="product-card">
  <div class="product-card__image-container">
    <!-- Badges -->
    <div class="product-card__badges">
      {% if product.available == false %}
        <span class="product-card__badge product-card__badge--sold-out">Sold Out</span>
      {% endif %}

      {% assign badge = product.metafields.custom.product_badge.value %}
      {% if badge != blank %}
        <span
          class="product-card__badge"
          style="background-color: {{ badge.badge_bg }}; color: {{ badge.badge_color }};"
        >
          {{ badge.badge_text }}
        </span>
      {% endif %}

      {% comment %}
        Logic for 'Bestseller' and 'New' can be added here if you have tags or other metafields.
        Below is an example using tags for demonstration.
      {% endcomment %}
      {% if product.tags contains 'Bestseller' %}
        <span class="product-card__badge product-card__badge--bestseller">Bestseller</span>
      {% endif %}
      {% if product.tags contains 'New' %}
        <span class="product-card__badge product-card__badge--new">New</span>
      {% endif %}
    </div>

    <!-- Wishlist -->
    <button
      type="button"
      class="product-card__wishlist"
      aria-label="Add to Wishlist"
      data-wishlist-toggle="{{ product.handle }}"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
      </svg>
    </button>

    <!-- Product Image -->
    <a href="{{ product.url }}" class="product-card__image-link h-full w-full flex items-center justify-center">
      {% if product.featured_image %}
        <img
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.title }}"
          width="600"
          height="600"
          loading="lazy"
        >
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'w-full h-full' }}
      {% endif %}
    </a>

    <!-- Quick Add -->
    {% unless hide_quick_add %}
      {% if product.available %}
        <div class="product-card__quick-add-wrap">
          <button
            type="button"
            data-action="quick-add"
            data-variant-id="{{ product.first_available_variant.id }}"
            class="product-card__quick-add-btn"
            aria-label="Quick Add to Cart"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
            </svg>
          </button>
        </div>
      {% endif %}
    {% endunless %}
  </div>

  <div class="product-card__info">
    <a href="{{ product.url }}" class="product-card__title">
      {{ product.title }}
    </a>

    <div class="product-card__price-row">
      <span class="product-card__price">{{ product.price | money }}</span>
      {% comment %} Example unit price logic {% endcomment %}
      {% if product.selected_or_first_available_variant.unit_price_measurement %}
        <span class="product-card__unit-price">
          ({{ product.selected_or_first_available_variant.unit_price | money }}/
          {{- product.selected_or_first_available_variant.unit_price_measurement.reference_unit -}}
          )
        </span>
      {% endif %}
    </div>
  </div>
</div>
