<div class="product-card">
  <!-- Image Container -->
  <div class="product-image-container">
    <a href="{{ product.url }}" class="block h-full w-full">
      {% if product.featured_image %}
        <img
          src="{{ product.featured_image | image_url: width: 800 }}"
          alt="{{ product.title }}"
          class="product-image"
          width="800"
          height="800"
          loading="lazy"
        >
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'product-image' }}
      {% endif %}
    </a>

    <!-- Badges -->
    <div class="product-card__badges">
      {% assign custom_badge = product.metafields.custom.product_badge.value %}
      {% if custom_badge != blank %}
        <div
          class="badge badge--custom"
          style="background: {{ custom_badge.badge_bg }}; color: {{ custom_badge.badge_color }};"
        >
          {{ custom_badge.badge_text }}
        </div>
      {% endif %}
    </div>

    <!-- Wishlist Button -->
    <button
      type="button"
      class="wishlist-btn"
      aria-label="Add to Wishlist"
      data-wishlist-toggle="{{ product.handle }}"
    >
      <svg
        class="heart-icon"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
      </svg>
    </button>

    <!-- Quick Add (Maintained for functionality) -->
    {% unless hide_quick_add %}
      {% if product.available %}
        <div class="product-card__quick-add-wrap">
          <button
            type="button"
            data-action="quick-add"
            data-variant-id="{{ product.first_available_variant.id }}"
            class="product-card__quick-add-btn"
            aria-label="Quick Add to Cart"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              <path d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
            </svg>
          </button>
        </div>
      {% endif %}
    {% endunless %}
  </div>

  <!-- Product Info -->
  <div class="product-info">
    <a href="{{ product.url }}" class="product-title">{{ product.title }}</a>

    <div class="price-container">
      <span class="current-price">{{ product.price | money }}</span>
      {% if product.compare_at_price > product.price %}
        <span class="original-price">{{ product.compare_at_price | money }}</span>
      {% endif %}
    </div>
  </div>
</div>
