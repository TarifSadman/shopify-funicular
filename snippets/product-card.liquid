<div class="group h-full">
  <div class="relative overflow-hidden border bg-white shadow-sm transition hover:shadow-md">
    {% if product.available == false %}
      <div class="sold-out-badge">
        <div class="sold-out-badge__circle">
          <div class="sold-out-badge__inner">
            <span class="sold-out-badge__text">
              SOLD<br>
              OUT
            </span>
          </div>
        </div>
      </div>
    {% endif %}

    <a href="{{ product.url }}" class="block">
      {% if product.featured_image %}
        <div class="product-card__image-wrap bg-gray-50">
          <img
            src="{{ product.featured_image | image_url: width: 400 }}"
            alt="{{ product.title }}"
            class="h-full w-full object-contain transition duration-300 hover:scale-105"
            width="400"
            height="400"
          >
        </div>
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'w-full product-card__image-wrap bg-gray-100' }}
      {% endif %}
    </a>

    {% unless hide_quick_add %}
      {% if product.available %}
        <button
          type="button"
          data-action="quick-add"
          data-variant-id="{{ product.first_available_variant.id }}"
          class="product-card__quick-add"
          aria-label="Quick Add to Cart"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="3"
            stroke="currentColor"
            class="w-4 h-4"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
        </button>
      {% endif %}
    {% endunless %}

    <div class="flex flex-col gap-1 p-4">
      <span class="text-xs uppercase tracking-wide text-gray-400">
        {{ product.vendor }}
      </span>

      <a
        href="{{ product.url }}"
        class="text-sm font-medium uppercase text-gray-800 hover:text-black transition"
      >
        {{ product.title }}
      </a>

      <p class="text-sm font-semibold text-gray-700">
        {{ product.price | money }}
      </p>
    </div>
  </div>
</div>
